# ===========================================
# Vercel Config Demo - Environment Variables
# ===========================================
# Copy this file to .env.local for local development

# -------------------------------------------
# Demo Environment Variables
# These demonstrate build-time vs runtime config
# -------------------------------------------
DEMO_BRAND_NAME=Crocs
DEMO_API_BASE_URL=https://api.example.com
DEMO_PROMO_BANNER_TEXT=Free shipping on orders over $50!
DEMO_COLOR_THEME=light

# -------------------------------------------
# Feature Flags (local overrides)
# In production, these come from Statsig
# -------------------------------------------
FLAG_NEW_PDP_LAYOUT=false
FLAG_FREE_SHIPPING_THRESHOLD=50
FLAG_CHECKOUT_VARIANT=control

# -------------------------------------------
# Statsig Configuration
# Get these from your Statsig project
# -------------------------------------------
STATSIG_SERVER_SECRET=secret-your-statsig-server-key
STATSIG_CLIENT_KEY=client-your-statsig-client-key

# -------------------------------------------
# Edge Config
# This is automatically set when you link an Edge Config store
# Format: https://edge-config.vercel.com/<id>?token=<token>
# -------------------------------------------
EDGE_CONFIG=

# -------------------------------------------
# Vercel System Variables (auto-populated)
# These are set automatically in Vercel deployments
# You can enable "Automatically expose System Environment Variables"
# in Project Settings to access them in your code
# -------------------------------------------
# VERCEL_ENV=development|preview|production
# VERCEL_URL=your-deployment-url.vercel.app
# VERCEL_GIT_COMMIT_REF=branch-name
# VERCEL_GIT_COMMIT_SHA=commit-sha
